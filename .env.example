# Supabase — create a project at https://supabase.com, then Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
# For real patient-adjacent data you need a BAA-covered account tier before going live.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Base URL used for email-verification / password-reset redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Billing — https://dashboard.stripe.com/apikeys for the secret key,
# create a "Practice" monthly price ($249) under Product catalog to get
# STRIPE_PRICE_ID_PRACTICE, and https://dashboard.stripe.com/webhooks to add
# an endpoint at /api/webhooks/stripe for the webhook signing secret. Turn on
# Stripe Tax (https://dashboard.stripe.com/tax) so checkout collects the
# right sales tax automatically.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRACTICE=

# Resend — https://resend.com/api-keys (transactional email). If unset, emails
# are logged to the server console instead of sent, so local dev works either way.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Clearway <notifications@clearway.health>

# Secret header the /api/cron/purge-expired route requires. Set this in Vercel
# and reference it from vercel.json's cron config.
CRON_SECRET=
